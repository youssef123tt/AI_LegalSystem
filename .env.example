# Copy to .env and adjust as needed.

# App
APP_ENV=dev
APP_NAME=ai-legal-knowledge-assistant

# API
API_HOST=0.0.0.0
API_PORT=8000

# Postgres
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=legal_rag
POSTGRES_USER=legal
POSTGRES_PASSWORD=legal

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# OpenSearch
OPENSEARCH_URL=http://opensearch:9200

# OpenSearch indexes
OPENSEARCH_CHUNKS_INDEX=chunks_v2
OPENSEARCH_CHUNKS_ALIAS=chunks_current
OPENSEARCH_INIT_ON_STARTUP=false

# Embeddings (OpenRouter)
EMBEDDINGS_BASE_URL=https://openrouter.ai/api/v1
EMBEDDINGS_MODEL=google/gemini-embedding-001
# Leave empty for provider default; set to match your OpenSearch knn_vector dimension.
EMBEDDINGS_DIMENSIONS=3072
EMBEDDINGS_BATCH_SIZE=16
EMBEDDINGS_MAX_CHARS=8000
# Do NOT commit secrets:
EMBEDDINGS_API_KEY=

# LLM generation (chat/reports)
LLM_PROVIDER_DEFAULT=openrouter
CHAT_MODEL=google/gemma-3-4b-it:free
CHAT_FALLBACK_MODELS=openrouter/free
CHAT_MAX_TOKENS=4096

# Native Gemini (optional)
GEMINI_API_KEY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
GEMINI_CHAT_MODEL=gemini-2.5-flash

# OCR (Milestone 4/Arabic PDF fallback)
OCR_LANGS=ara+eng
OCR_DPI=300
OCR_CONFIDENCE_MIN=60

# Upload (Milestone 2+)
UPLOAD_DIR=/data/uploads
